@page
@model InvoiceApp.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0">Settings</h5>
    <a href="/Settings/Rooms" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-house-door"></i> Manage Rooms
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger py-2 mb-3">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2">@Model.StatusMessage</div>
}

<form method="post">
    <div class="card mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-building"></i> Company Details
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Company Name</label>
                <input asp-for="Company.Name" class="form-control" placeholder="e.g. Lifestar Builders (PTY) LTD" />
            </div>
            <div class="mb-3">
                <label class="form-label">Address Line 1</label>
                <input asp-for="Company.AddressLine1" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Address Line 2</label>
                <input asp-for="Company.AddressLine2" class="form-control" />
            </div>
            <div class="row g-2 mb-3">
                <div class="col-8">
                    <label class="form-label">City</label>
                    <input asp-for="Company.City" class="form-control" />
                </div>
                <div class="col-4">
                    <label class="form-label">Postal Code</label>
                    <input asp-for="Company.PostalCode" class="form-control" />
                </div>
            </div>
            <div class="mb-2">
                <label class="form-label">Phone</label>
                <input asp-for="Company.Phone" class="form-control" placeholder="e.g. 066 378 7872" />
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-bank"></i> Banking Details
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Bank Name</label>
                <input asp-for="Banking.BankName" class="form-control" placeholder="e.g. Capitec Bank" />
            </div>
            <div class="mb-3">
                <label class="form-label">Account Type</label>
                <select asp-for="Banking.AccountType" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="Savings">Savings</option>
                    <option value="Cheque">Cheque</option>
                    <option value="Current">Current</option>
                    <option value="Business">Business</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Account Number</label>
                <input asp-for="Banking.AccountNumber" class="form-control" />
            </div>
            <div class="mb-2">
                <label class="form-label">Branch Code</label>
                <input asp-for="Banking.BranchCode" class="form-control" placeholder="e.g. 470010" />
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-save"></i> Save Settings
    </button>
</form>
