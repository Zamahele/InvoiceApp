@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mt-1">
    <div class="col-12">
        <h4 class="fw-bold">Dashboard</h4>
    </div>
    <div class="col-6">
        <a href="/Invoices/Create" class="text-decoration-none">
            <div class="card text-center border-primary h-100">
                <div class="card-body py-4">
                    <i class="bi bi-plus-circle fs-1 text-primary"></i>
                    <p class="mt-2 fw-semibold mb-0">New Invoice</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6">
        <a href="/Invoices/History" class="text-decoration-none">
            <div class="card text-center border-secondary h-100">
                <div class="card-body py-4">
                    <i class="bi bi-clock-history fs-1 text-secondary"></i>
                    <p class="mt-2 fw-semibold mb-0">History</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6">
        <a href="/Settings" class="text-decoration-none">
            <div class="card text-center border-warning h-100">
                <div class="card-body py-4">
                    <i class="bi bi-gear fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold mb-0">Settings</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6">
        <a href="/Settings/Rates" class="text-decoration-none">
            <div class="card text-center border-success h-100">
                <div class="card-body py-4">
                    <i class="bi bi-list-ul fs-1 text-success"></i>
                    <p class="mt-2 fw-semibold mb-0">Rate Library</p>
                </div>
            </div>
        </a>
    </div>
</div>
