@page
@{
    ViewData["Title"] = "You're Offline";
    Layout = "_Layout";
}

<div class="text-center py-5">
    <i class="bi bi-wifi-off text-muted" style="font-size: 4rem;"></i>
    <h4 class="mt-3 fw-bold">You're offline</h4>
    <p class="text-muted mt-2">
        BlackTech Portal requires an internet connection to load your invoices and rent data.
    </p>
    <p class="text-muted small">
        Please check your connection and try again.
    </p>
    <button class="btn btn-primary mt-2" onclick="window.location.reload()">
        <i class="bi bi-arrow-clockwise"></i> Try Again
    </button>
</div>
